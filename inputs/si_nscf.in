&CONTROL
    calculation = 'nscf',
    prefix = 'si',
    pseudo_dir = './pseudo/',
    outdir = './tmp/'
/

&SYSTEM
    ibrav = 2,
    celldm(1) = 10.33720283,
    nat = 2,
    ntyp = 1,
    ecutwfc = 40.0,
    ecutrho = 320.0,
    occupations = 'fixed',
    nbnd = 8
/

&ELECTRONS
    conv_thr = 1.0d-8
/

ATOMIC_SPECIES
Si  28.0855  Si.pbe-n-kjpaw_psl.1.0.0.UPF

ATOMIC_POSITIONS crystal
Si  0.00  0.00  0.00
Si  0.25  0.25  0.25

K_POINTS automatic
12 12 12 0 0 0
